[options]
addons_path = /usr/lib/python3/dist-packages/odoo/addons,/mnt/extra-addons/partner-contact,/mnt/extra-addons/server-tools,/mnt/extra-addons/server-ux,/mnt/extra-addons/server-auth,/mnt/extra-addons/server-backend,/mnt/extra-addons/queue,/mnt/extra-addons/account-reconcile,/mnt/extra-addons/account-financial-tools,/mnt/extra-addons/account-analytic,/mnt/extra-addons/mis-builder,/mnt/extra-addons/account-financial-reporting,/mnt/extra-addons/reporting-engine,/mnt/extra-addons/account-budgeting,/mnt/extra-addons/bank-payment,/mnt/extra-addons/purchase-workflow,/mnt/extra-addons/hr-expense,/mnt/extra-addons/payroll,/mnt/extra-addons/contract
data_dir = /var/lib/odoo

db_host = postgres
db_port = 5432
db_user = odoo
db_password = __POSTGRES_PASSWORD__
db_maxconn = 64

admin_passwd = __ODOO_ADMIN_PASSWD__
list_db = False
db_filter = ^nonprofit$
dbfilter = ^nonprofit$

workers = 7
max_cron_threads = 2

limit_memory_soft = 671088640
limit_memory_hard = 838860800
limit_request = 8192
limit_time_cpu = 600
limit_time_real = 1200
limit_time_real_cron = -1

proxy_mode = True
without_demo = True

log_level = info
log_handler = :INFO
logfile = False
